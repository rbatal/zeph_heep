#
# Interrupt Controller Kconfig
#

config XHEEP_PLIC
  bool "X-HEEP Platform-Level Interrupt Controller"
  default y
  depends on RISCV_HAS_PLIC
  depends on !PLIC
  select MULTI_LEVEL_INTERRUPTS
  select 2ND_LEVEL_INTERRUPTS
  help
    Custom PLIC driver for the X-HEEP platform.
    The lowRISC/OpenTitan rv_plic in X-HEEP uses a compact
    register layout that is NOT compatible with the standard
    RISC-V PLIC memory map expected by Zephyr's built-in
    intc_plic.c driver.

    This driver provides the riscv_plic_* API using the correct
    compact register offsets.
